<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>스터디 플래너</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Gaegu:wght@400;700&family=Noto+Sans+KR:wght@400;500;700;900&display=swap" rel="stylesheet">
<style>
  :root{
    --paper:#F2F6F1;
    --paper-dark:#E6EEE2;
    --ink:#26332E;
    --ink-soft:#5B6B63;
    --sage:#4E7C6B;
    --sage-dark:#38594C;
    --mustard:#E3A23C;
    --blush:#E8A0A0;
    --white:#FFFFFF;
    --line:#D8E3D6;
    --shadow: 0 6px 18px rgba(38,51,46,0.08);
  }
  *{box-sizing:border-box;}
  body{
    margin:0;
    background:
      linear-gradient(var(--paper-dark) 1px, transparent 1px),
      linear-gradient(90deg, var(--paper-dark) 1px, transparent 1px),
      var(--paper);
    background-size: 28px 28px, 28px 28px, cover;
    color:var(--ink);
    font-family:'Noto Sans KR', sans-serif;
    min-height:100vh;
    padding: 28px 16px 60px;
  }
  .wrap{max-width:1080px;margin:0 auto;}
  h1,h2,.hand{font-family:'Gaegu', cursive;}
  /* ---- Header ---- */
  header{
    position:relative;
    background:var(--white);
    border-radius:18px;
    box-shadow:var(--shadow);
    padding:26px 28px 22px;
    margin-bottom:22px;
    display:flex; justify-content:space-between; align-items:flex-end; flex-wrap:wrap; gap:16px;
  }
  .tape{
    position:absolute; top:-12px; height:26px; width:90px;
    background: repeating-linear-gradient(135deg, var(--mustard), var(--mustard) 6px, #eab662 6px, #eab662 12px);
    opacity:.85; box-shadow:0 2px 4px rgba(0,0,0,.12);
  }
  .tape.left{left:36px; transform:rotate(-6deg);}
  .tape.right{right:44px; transform:rotate(5deg); background:repeating-linear-gradient(135deg, var(--blush), var(--blush) 6px, #f0bcbc 6px, #f0bcbc 12px);}
  header h1{font-size:34px; margin:0 0 4px; color:var(--sage-dark); font-weight:700;}
  header p{margin:0; color:var(--ink-soft); font-size:14px;}
  .sync{font-size:12px; color:var(--ink-soft); display:flex; align-items:center; gap:6px;}
  .dot{width:8px;height:8px;border-radius:50%;background:var(--sage); transition:.3s;}
  .dot.saving{background:var(--mustard); animation:pulse 1s infinite;}
  @keyframes pulse{0%,100%{opacity:1;}50%{opacity:.3;}}

  .dday-box{
    background:var(--paper);
    border:1.5px dashed var(--sage);
    border-radius:14px;
    padding:12px 18px;
    text-align:center;
    min-width:180px;
  }
  .dday-box .num{font-family:'Gaegu',cursive; font-size:38px; color:var(--mustard); line-height:1; font-weight:700;}
  .dday-box .lbl{font-size:12px; color:var(--ink-soft); margin-top:2px;}
  .dday-edit{display:flex; gap:6px; margin-top:8px; flex-wrap:wrap; justify-content:center; align-items:center;}
  .dday-edit input{font-size:12px; padding:4px 6px; border:1px solid var(--line); border-radius:6px; width:92px; font-family:inherit;}
  .dday-edit button{padding:5px 10px; font-size:12px;}

  /* ---- Layout ---- */
  main{display:grid; grid-template-columns:1.5fr 1fr; gap:20px;}
  @media (max-width:820px){ main{grid-template-columns:1fr;} }

  .card{
    background:var(--white);
    border-radius:18px;
    box-shadow:var(--shadow);
    padding:22px 22px 24px;
    position:relative;
    margin-bottom:20px;
  }
  .card .tape{top:-10px; left:28px; width:64px; height:20px;}
  .card h2{font-size:22px; color:var(--sage-dark); margin:4px 0 16px; display:flex; align-items:center; gap:8px;}

  /* Tasks */
  .task-form{display:flex; gap:8px; margin-bottom:14px; flex-wrap:wrap;}
  select, input[type=text], input[type=number], input[type=date]{
    font-family:'Noto Sans KR', sans-serif;
    padding:9px 10px; border:1px solid var(--line); border-radius:8px; font-size:14px; background:var(--paper);
  }
  .task-form select{flex:0 0 110px;}
  .task-form input[type=text]{flex:1; min-width:120px;}
  button{
    cursor:pointer; border:none; border-radius:8px; padding:9px 16px;
    background:var(--sage); color:#fff; font-family:'Noto Sans KR'; font-weight:500; font-size:14px;
    transition:.15s;
  }
  button:hover{background:var(--sage-dark); transform:translateY(-1px);}
  button.ghost{background:transparent; color:var(--ink-soft); border:1px solid var(--line);}
  button.ghost:hover{background:var(--paper-dark); color:var(--ink);}

  ul.tasks{list-style:none; margin:0; padding:0;}
  ul.tasks li{
    display:flex; align-items:center; gap:10px;
    padding:10px 8px; border-bottom:1px solid var(--line);
  }
  ul.tasks li:last-child{border-bottom:none;}
  .tag{
    font-size:11px; padding:3px 9px; border-radius:20px; color:#fff; white-space:nowrap; font-weight:500;
  }
  .task-text{flex:1; font-size:14.5px;}
  .task-text.done{text-decoration:line-through; color:#a8b3ad;}
  .checkbox{
    width:20px; height:20px; border-radius:6px; border:2px solid var(--sage);
    display:flex; align-items:center; justify-content:center; cursor:pointer; flex:0 0 auto;
    background:#fff;
  }
  .checkbox.checked{background:var(--sage); color:#fff; font-size:13px;}
  .del{background:none; border:none; color:#c4a3a3; font-size:16px; padding:2px 6px;}
  .del:hover{color:var(--blush); background:none; transform:none;}
  .empty{color:var(--ink-soft); font-size:13px; padding:10px 4px;}

  /* Subjects / goals */
  .subject-form{display:flex; gap:8px; margin-bottom:14px; flex-wrap:wrap;}
  .subject-form input[type=text]{width:90px;}
  .subject-form input[type=number]{width:80px;}
  .color-dot{width:26px;height:26px;border-radius:50%;border:2px solid var(--line); cursor:pointer;}
  .swatches{display:flex; gap:6px; align-items:center;}
  .swatches .color-dot.selected{border-color:var(--ink);}

  .subject-row{margin-bottom:16px;}
  .subject-row .top{display:flex; justify-content:space-between; align-items:center; font-size:13.5px; margin-bottom:6px;}
  .subject-row .top .name{display:flex; align-items:center; gap:8px; font-weight:500;}
  .swatch{width:12px;height:12px;border-radius:50%;display:inline-block;}
  .bar-track{background:var(--paper-dark); border-radius:10px; height:16px; overflow:hidden; position:relative;}
  .bar-fill{
    height:100%; border-radius:10px 4px 10px 4px;
    background:linear-gradient(90deg, var(--mustard), var(--sage));
    transition: width .4s ease;
    box-shadow: inset 0 0 0 1.5px rgba(255,255,255,.4);
  }
  .subject-row .add-time{display:flex; gap:6px; margin-top:6px; flex-wrap:wrap; align-items:center;}
  .subject-row .add-time input{width:64px;}
  .subject-actions{display:flex; gap:4px;}
  .qbtn{
    padding:6px 10px; font-size:12.5px; background:var(--paper); color:var(--sage-dark);
    border:1px solid var(--line); font-weight:500;
  }
  .qbtn:hover{background:var(--paper-dark); color:var(--ink); transform:none;}

  /* Chip picker (subjects) */
  .chip-row{display:flex; gap:8px; flex-wrap:wrap; margin-bottom:10px;}
  .chip{
    padding:7px 14px; border-radius:20px; font-size:13.5px; cursor:pointer;
    border:1.5px solid var(--line); background:#fff; color:var(--ink-soft); font-weight:500;
    transition:.15s; user-select:none;
  }
  .chip:hover{border-color:var(--sage);}
  .chip.active{color:#fff; border-color:transparent;}
  .chip.preset{background:var(--paper); border-style:dashed;}
  .no-subject-hint{font-size:12.5px; color:var(--ink-soft); margin-bottom:10px;}

  /* Summary */
  .summary-grid{display:grid; grid-template-columns:1fr 1fr; gap:12px; text-align:center;}
  .summary-grid .stat{background:var(--paper); border-radius:12px; padding:14px 6px;}
  .summary-grid .stat .big{font-family:'Gaegu',cursive; font-size:30px; color:var(--sage-dark); font-weight:700;}
  .summary-grid .stat .small{font-size:12px; color:var(--ink-soft); margin-top:2px;}
  .motivate{margin-top:14px; text-align:center; font-size:14px; color:var(--sage-dark); font-family:'Gaegu',cursive; font-size:19px;}

  footer{text-align:center; color:var(--ink-soft); font-size:12px; margin-top:30px;}

  .offline-banner{
    display:none;
    background:#FDEDEA; border:1.5px solid var(--blush); color:#8A4A42;
    border-radius:12px; padding:12px 16px; font-size:13px; line-height:1.6;
    margin-bottom:16px;
  }

  /* Goal box */
  #goalInput{
    width:100%; min-height:150px; resize:vertical;
    font-family:'Noto Sans KR', sans-serif; font-size:14px; line-height:1.6;
    padding:14px; border:1px solid var(--line); border-radius:12px;
    background:
      repeating-linear-gradient(var(--paper) 0 27px, var(--line) 27px 28px);
    color:var(--ink);
  }
  #goalInput:focus{outline:2px solid var(--sage); outline-offset:1px;}
  .goal-sync{font-size:11.5px; color:var(--ink-soft); text-align:right; margin-top:6px;}
</style>
</head>
<body>
<div class="wrap">

  <div class="offline-banner" id="offlineBanner">
    ⚠️ 클라우드 저장 연결에 실패했어요. 지금은 이 화면에서만 임시로 작동하고, 새로고침하면 데이터가 사라져요.
    학교/회사 와이파이나 광고 차단 확장 프로그램이 Firebase 접속을 막고 있을 수 있어요 — 다른 네트워크(휴대폰 데이터 등)나 다른 브라우저에서 다시 열어보세요.
  </div>

  <header>
    <span class="tape left"></span>
    <span class="tape right"></span>
    <div>
      <h1 id="plannerTitle">김예린의 스터디 플래너</h1>
      <p>오늘도 한 걸음씩 🌿 데이터는 자동으로 저장돼요.</p>
      <div class="sync"><span class="dot" id="syncDot"></span><span id="syncText">저장됨</span></div>
    </div>
    <div class="dday-box">
      <div class="num" id="ddayNum">D-000</div>
      <div class="lbl" id="ddayLbl">목표일</div>
      <div class="dday-edit">
        <input type="text" id="ddayLabelInput" placeholder="예: 기말고사" />
        <input type="date" id="ddayDateInput" />
        <button id="ddaySaveBtn">설정</button>
      </div>
    </div>
  </header>

  <main>
    <!-- LEFT COLUMN -->
    <div>
      <div class="card">
        <span class="tape"></span>
        <h2>✅ 오늘의 할 일</h2>
        <div class="chip-row" id="taskSubjectChips"></div>
        <div class="task-form">
          <input type="text" id="taskText" placeholder="할 일을 입력하세요" />
          <button id="addTaskBtn">추가</button>
        </div>
        <ul class="tasks" id="taskList"></ul>
      </div>

      <div class="card">
        <span class="tape"></span>
        <h2>📚 과목별 이번 주 공부시간</h2>
        <p style="font-size:12.5px;color:var(--ink-soft);margin:-6px 0 10px;">원하는 과목을 눌러서 켜고 끌 수 있어요. 목록에 없으면 아래에서 직접 추가하세요.</p>
        <div class="chip-row" id="presetSubjectChips"></div>
        <div class="subject-form">
          <input type="text" id="subjectName" placeholder="직접 입력 (예: 제2외국어)" style="width:150px;" />
          <input type="number" id="subjectGoal" placeholder="목표(시간)" min="1" />
          <div class="swatches" id="colorSwatches"></div>
          <button id="addSubjectBtn">추가</button>
        </div>
        <div id="subjectList"></div>
        <button class="ghost" id="resetWeekBtn" style="margin-top:6px;">이번 주 기록 초기화</button>
      </div>
    </div>

    <!-- RIGHT COLUMN -->
    <div>
      <div class="card">
        <span class="tape"></span>
        <h2>📊 진행 요약</h2>
        <div class="summary-grid">
          <div class="stat">
            <div class="big" id="taskDoneStat">0/0</div>
            <div class="small">오늘 완료한 할 일</div>
          </div>
          <div class="stat">
            <div class="big" id="weekMinStat">0분</div>
            <div class="small">이번 주 총 공부시간</div>
          </div>
        </div>
        <div class="motivate" id="motivateText">오늘도 화이팅! 🌱</div>
      </div>

      <div class="card">
        <span class="tape"></span>
        <h2>🎯 나의 목표</h2>
        <p style="font-size:12.5px;color:var(--ink-soft);margin:4px 0 10px;">이번 주 · 이번 시험 목표를 적어두고 자주 들여다보세요.</p>
        <textarea id="goalInput" placeholder="예: 이번 기말고사 평균 5점 올리기, 수학 3단원 개념 완전정복..."></textarea>
        <div class="goal-sync" id="goalSyncText">저장됨</div>
      </div>
    </div>
  </main>

  <footer>Firebase로 자동 저장되는 나만의 스터디 플래너 · made with GPT/Claude</footer>
</div>

<!-- Firebase (CDN, compat) -->
<script src="https://www.gstatic.com/firebasejs/10.12.2/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/10.12.2/firebase-firestore-compat.js"></script>
<script>
/* =========================================================
   1) 학번/이름 설정 — 반드시 본인 정보로 바꿔주세요!
   ========================================================= */
const STUDENT_DOC_ID = "30101 김예린"; // 예: "30203 홍길동" 로 수정

/* =========================================================
   2) Firebase 설정 (그대로 사용)
   ========================================================= */
const firebaseConfig = {
  apiKey: "AIzaSyANA-lTFGboIfklqQewlVk49GUQ_Am33aE",
  authDomain: "garim-study-planner.firebaseapp.com",
  projectId: "garim-study-planner",
  storageBucket: "garim-study-planner.firebasestorage.app",
  messagingSenderId: "1048447885260",
  appId: "1:1048447885260:web:935234dd0c96860583c769"
};
let cloudAvailable = true;
let db = null;
let docRef = null;
try {
  if (typeof firebase === 'undefined') {
    throw new Error('Firebase SDK 스크립트가 로드되지 않았습니다 (네트워크 차단 가능성)');
  }
  firebase.initializeApp(firebaseConfig);
  db = firebase.firestore();
  docRef = db.collection('students').doc(STUDENT_DOC_ID);
} catch (err) {
  cloudAvailable = false;
  console.error('Firebase 연결 실패:', err);
}

/* =========================================================
   3) 앱 상태
   ========================================================= */
const COLORS = ['#4E7C6B','#E3A23C','#E8A0A0','#7C93C9','#B08BBB','#D98B5F'];
const PRESET_SUBJECTS = ['국어','영어','수학','사회','과학','한국사','도덕','제2외국어','정보','음악','미술','체육','진로','논술'];
let selectedTaskSubject = null;

let state = {
  dday: { label: '기말고사', date: '' },
  tasks: [],           // {id, subject, text, done}
  subjects: [],        // {id, name, color, goalHours, minutes}
  goalText: '',
};

let saveTimer = null;
let selectedColor = COLORS[0];
let loadedOnce = false;

/* ---------- Firestore 연동 ---------- */
if (cloudAvailable) {
  docRef.onSnapshot((snap) => {
    if (snap.exists) {
      const data = snap.data();
      state = {
        dday: data.dday || state.dday,
        tasks: data.tasks || [],
        subjects: data.subjects || [],
        goalText: data.goalText || '',
      };
    } else if (!loadedOnce) {
      // 최초 실행: 기본 과목 예시 생성
      state.subjects = [
        { id: cryptoId(), name:'수학', color: COLORS[0], goalHours: 5, minutes: 0 },
        { id: cryptoId(), name:'영어', color: COLORS[1], goalHours: 4, minutes: 0 },
      ];
      persist();
    }
    loadedOnce = true;
    renderAll();
  }, (err) => {
    // 연결 도중 오류가 나도 화면은 계속 쓸 수 있게 처리
    console.error('Firestore 오류:', err);
    cloudAvailable = false;
    document.getElementById('offlineBanner').style.display = 'block';
    if (!loadedOnce){
      state.subjects = [
        { id: cryptoId(), name:'수학', color: COLORS[0], goalHours: 5, minutes: 0 },
        { id: cryptoId(), name:'영어', color: COLORS[1], goalHours: 4, minutes: 0 },
      ];
    }
    loadedOnce = true;
    renderAll();
  });
} else {
  // Firebase 자체가 로드되지 않은 경우: 로컬 상태로 즉시 화면을 그린다
  document.getElementById('offlineBanner').style.display = 'block';
  state.subjects = [
    { id: cryptoId(), name:'수학', color: COLORS[0], goalHours: 5, minutes: 0 },
    { id: cryptoId(), name:'영어', color: COLORS[1], goalHours: 4, minutes: 0 },
  ];
  loadedOnce = true;
  renderAll();
  setSyncing(false);
}

function persist(){
  if (!cloudAvailable){ return; } // 오프라인 모드: 화면은 이미 갱신됨, 저장만 건너뜀
  setSyncing(true);
  clearTimeout(saveTimer);
  saveTimer = setTimeout(() => {
    docRef.set(state, { merge: false })
      .then(() => setSyncing(false))
      .catch((err) => {
        console.error('저장 실패:', err);
        cloudAvailable = false;
        document.getElementById('offlineBanner').style.display = 'block';
        setSyncing(false);
      });
  }, 400);
}

function setSyncing(isSaving){
  const dot = document.getElementById('syncDot');
  const txt = document.getElementById('syncText');
  if (!cloudAvailable){ dot.style.background = '#c9938c'; txt.textContent = '오프라인'; return; }
  if (isSaving){ dot.classList.add('saving'); txt.textContent = '저장 중...'; }
  else { dot.classList.remove('saving'); txt.textContent = '저장됨'; }
}

function cryptoId(){ return Math.random().toString(36).slice(2,10); }

/* =========================================================
   4) 렌더링
   ========================================================= */
function renderAll(){
  renderDday();
  renderSubjectSelect();
  renderPresetSubjects();
  renderTasks();
  renderSubjects();
  renderSummary();
  renderSwatches();
  renderGoal();
}

/* --- D-Day --- */
function renderDday(){
  document.getElementById('ddayLabelInput').value = state.dday.label || '';
  document.getElementById('ddayDateInput').value = state.dday.date || '';
  const lbl = document.getElementById('ddayLbl');
  const num = document.getElementById('ddayNum');
  lbl.textContent = state.dday.label || '목표일을 설정하세요';
  if (state.dday.date){
    const today = new Date(); today.setHours(0,0,0,0);
    const target = new Date(state.dday.date); target.setHours(0,0,0,0);
    const diff = Math.round((target - today) / 86400000);
    num.textContent = diff === 0 ? 'D-DAY' : (diff > 0 ? `D-${diff}` : `D+${Math.abs(diff)}`);
  } else {
    num.textContent = 'D-?';
  }
}
document.getElementById('ddaySaveBtn').addEventListener('click', () => {
  const label = document.getElementById('ddayLabelInput').value.trim();
  const date = document.getElementById('ddayDateInput').value;
  if (!date){ alert('목표 날짜를 선택해주세요.'); return; }
  state.dday = { label: label || '목표일', date };
  renderDday();
  persist();
  const btn = document.getElementById('ddaySaveBtn');
  const old = btn.textContent;
  btn.textContent = '적용됨 ✓';
  setTimeout(()=>{ btn.textContent = old; }, 1200);
});

/* --- Tasks --- */
function renderSubjectSelect(){
  const box = document.getElementById('taskSubjectChips');
  if (state.subjects.length === 0){
    box.innerHTML = '<div class="no-subject-hint">먼저 아래 "과목별 공부시간"에서 과목을 추가해주세요 👇</div>';
    selectedTaskSubject = null;
    return;
  }
  if (!selectedTaskSubject || !state.subjects.find(s=>s.id===selectedTaskSubject)){
    selectedTaskSubject = state.subjects[0].id;
  }
  box.innerHTML = state.subjects.map(s => {
    const active = s.id === selectedTaskSubject;
    return `<div class="chip ${active?'active':''}" style="${active?`background:${s.color};`:''}" onclick="selectTaskSubject('${s.id}')">${escapeHtml(s.name)}</div>`;
  }).join('');
}
function selectTaskSubject(id){ selectedTaskSubject = id; renderSubjectSelect(); }

function renderPresetSubjects(){
  const box = document.getElementById('presetSubjectChips');
  box.innerHTML = PRESET_SUBJECTS.map(name => {
    const existing = state.subjects.find(s=>s.name===name);
    const active = !!existing;
    const style = active ? `background:${existing.color};border-color:transparent;` : '';
    return `<div class="chip preset ${active?'active':''}" style="${style}" onclick="toggleSubjectPreset('${name}')">${active?'✓ ':'+ '}${name}</div>`;
  }).join('');
}
function toggleSubjectPreset(name){
  const existing = state.subjects.find(s=>s.name===name);
  if (existing){
    const hasTasks = state.tasks.some(t=>t.subject===existing.id);
    if (hasTasks && !confirm(`'${name}' 과목에 등록된 할 일도 함께 삭제돼요. 계속할까요?`)) return;
    deleteSubject(existing.id);
  } else {
    quickAddSubject(name);
  }
}
function quickAddSubject(name){
  const usedColors = state.subjects.map(s=>s.color);
  const color = COLORS.find(c=>!usedColors.includes(c)) || COLORS[state.subjects.length % COLORS.length];
  state.subjects.push({ id: cryptoId(), name, color, goalHours: 3, minutes: 0 });
  renderSubjectSelect(); renderSubjects(); renderPresetSubjects(); persist();
}

function renderTasks(){
  const list = document.getElementById('taskList');
  if (state.tasks.length === 0){
    list.innerHTML = '<li class="empty">아직 할 일이 없어요. 위에서 추가해보세요!</li>';
    return;
  }
  list.innerHTML = state.tasks.map(t => {
    const subj = state.subjects.find(s => s.id === t.subject);
    const color = subj ? subj.color : '#999';
    const name = subj ? subj.name : '기타';
    return `
      <li>
        <div class="checkbox ${t.done ? 'checked' : ''}" onclick="toggleTask('${t.id}')">${t.done ? '✓' : ''}</div>
        <span class="tag" style="background:${color}">${escapeHtml(name)}</span>
        <span class="task-text ${t.done ? 'done' : ''}">${escapeHtml(t.text)}</span>
        <button class="del" onclick="deleteTask('${t.id}')">✕</button>
      </li>`;
  }).join('');
}

document.getElementById('addTaskBtn').addEventListener('click', addTask);
document.getElementById('taskText').addEventListener('keydown', (e)=>{ if(e.key==='Enter') addTask(); });

function addTask(){
  const textInput = document.getElementById('taskText');
  const text = textInput.value.trim();
  if (!text) return;
  if (!selectedTaskSubject){ alert('먼저 과목을 하나 이상 추가하고 선택해주세요.'); return; }
  state.tasks.push({ id: cryptoId(), subject: selectedTaskSubject, text, done:false });
  textInput.value = '';
  renderTasks(); renderSummary(); persist();
}
function toggleTask(id){
  const t = state.tasks.find(t=>t.id===id);
  if (t) t.done = !t.done;
  renderTasks(); renderSummary(); persist();
}
function deleteTask(id){
  state.tasks = state.tasks.filter(t=>t.id!==id);
  renderTasks(); renderSummary(); persist();
}

/* --- Subjects / study time --- */
function renderSwatches(){
  const box = document.getElementById('colorSwatches');
  box.innerHTML = COLORS.map(c => `<div class="color-dot ${c===selectedColor?'selected':''}" style="background:${c}" onclick="pickColor('${c}')"></div>`).join('');
}
function pickColor(c){ selectedColor = c; renderSwatches(); }

document.getElementById('addSubjectBtn').addEventListener('click', () => {
  const nameInput = document.getElementById('subjectName');
  const goalInput = document.getElementById('subjectGoal');
  const name = nameInput.value.trim();
  const goal = parseFloat(goalInput.value) || 3;
  if (!name) return;
  state.subjects.push({ id: cryptoId(), name, color: selectedColor, goalHours: goal, minutes: 0 });
  nameInput.value=''; goalInput.value='';
  renderSubjectSelect(); renderSubjects(); renderPresetSubjects(); persist();
});

function renderSubjects(){
  const box = document.getElementById('subjectList');
  if (state.subjects.length === 0){
    box.innerHTML = '<div class="empty">과목을 추가하면 여기에 목표 진행률이 표시돼요.</div>';
    return;
  }
  box.innerHTML = state.subjects.map(s => {
    const goalMin = s.goalHours * 60;
    const pct = goalMin > 0 ? Math.min(100, Math.round((s.minutes / goalMin) * 100)) : 0;
    return `
    <div class="subject-row">
      <div class="top">
        <div class="name"><span class="swatch" style="background:${s.color}"></span>${escapeHtml(s.name)} · ${Math.round(s.minutes/6)/10}h / ${s.goalHours}h</div>
        <div class="subject-actions">
          <button class="del" onclick="deleteSubject('${s.id}')">✕</button>
        </div>
      </div>
      <div class="bar-track"><div class="bar-fill" style="width:${pct}%"></div></div>
      <div class="add-time">
        <button class="qbtn" onclick="addMinutes('${s.id}',10)">+10분</button>
        <button class="qbtn" onclick="addMinutes('${s.id}',30)">+30분</button>
        <button class="qbtn" onclick="addMinutes('${s.id}',60)">+1시간</button>
        <input type="number" min="1" placeholder="직접입력(분)" id="min-${s.id}" style="width:96px;" />
        <button class="ghost" onclick="addMinutesManual('${s.id}')">기록</button>
      </div>
    </div>`;
  }).join('');
}
function addMinutes(id, mins){
  const s = state.subjects.find(s=>s.id===id);
  if (s) s.minutes += mins;
  renderSubjects(); renderSummary(); persist();
}
function addMinutesManual(id){
  const input = document.getElementById(`min-${id}`);
  const mins = parseFloat(input.value);
  if (!mins || mins<=0) return;
  addMinutes(id, mins);
  const freshInput = document.getElementById(`min-${id}`);
  if (freshInput) freshInput.value = '';
}
function deleteSubject(id){
  state.subjects = state.subjects.filter(s=>s.id!==id);
  state.tasks = state.tasks.filter(t=>t.subject!==id);
  renderSubjectSelect(); renderSubjects(); renderTasks(); renderPresetSubjects(); renderSummary(); persist();
}

/* --- Summary --- */
function renderSummary(){
  const done = state.tasks.filter(t=>t.done).length;
  document.getElementById('taskDoneStat').textContent = `${done}/${state.tasks.length}`;
  const totalMin = state.subjects.reduce((a,s)=>a+s.minutes,0);
  document.getElementById('weekMinStat').textContent = `${Math.round(totalMin)}분`;

  const ratio = state.tasks.length ? done/state.tasks.length : 0;
  let msg = '오늘도 화이팅! 🌱';
  if (ratio >= 1 && state.tasks.length>0) msg = '오늘 할 일 다 끝냈어요! 최고예요 🎉';
  else if (ratio >= 0.5) msg = '좋아요, 절반 넘게 왔어요! 계속 가봐요 🔥';
  else if (totalMin >= 60) msg = '벌써 한 시간 넘게 공부했네요, 대단해요 ✨';
  document.getElementById('motivateText').textContent = msg;
}

function escapeHtml(str){
  return String(str).replace(/[&<>"']/g, (c) => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
}

/* --- Goal box --- */
let goalSaveTimer = null;
function renderGoal(){
  const box = document.getElementById('goalInput');
  // 입력 중일 때는 값을 덮어쓰지 않음 (D-Day에서 겪었던 커서 튐 버그 방지)
  if (document.activeElement !== box){
    box.value = state.goalText || '';
  }
}
document.getElementById('goalInput').addEventListener('input', (e) => {
  state.goalText = e.target.value;
  const status = document.getElementById('goalSyncText');
  status.textContent = '저장 중...';
  clearTimeout(goalSaveTimer);
  goalSaveTimer = setTimeout(() => {
    persist();
    status.textContent = '저장됨';
  }, 500);
});

/* --- Reset week --- */
document.getElementById('resetWeekBtn').addEventListener('click', () => {
  if (!confirm('이번 주 공부시간 기록을 모두 초기화할까요?')) return;
  state.subjects.forEach(s => s.minutes = 0);
  renderSubjects(); renderSummary(); persist();
});

// expose for inline handlers
window.toggleTask = toggleTask;
window.deleteTask = deleteTask;
window.pickColor = pickColor;
window.addMinutes = addMinutes;
window.addMinutesManual = addMinutesManual;
window.deleteSubject = deleteSubject;
window.selectTaskSubject = selectTaskSubject;
window.quickAddSubject = quickAddSubject;
window.toggleSubjectPreset = toggleSubjectPreset;
</script>
</body>
</html>
